yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
  sudo yabai --load-sa

# bsp, stack or float
yabai -m config layout bsp

yabai -m config window_placement second_child

# Line from a user's plug-in for sketchy bar, to link them I guess
yabai -m signal --add event=window_focused action="sketchybar -m --trigger window_focus &> /dev/null"

# padding
yabai -m config top_padding 0
yabai -m config bottom_padding 5
yabai -m config left_padding 5
yabai -m config right_padding 5
yabai -m config window_gap 5

# mouse settings
yabai -m config mouse_follows_focus off

yabai -m config mouse_modifier alt
# left click + drag
yabai -m config mouse_action1 move
# right click + drag
yabai -m config mouse_action2 resize

yabai -m config mouse_drop_action swap

# Disable specific apps
yabai -m rule --add app='^System Settings$' manage=off
yabai -m rule --add app='^Calculator$' manage=off
yabai -m signal --add event=window_created app="^Blitzit$" action='yabai -m window $YABAI_WINDOW_ID --toggle float'

# Tell Yabai about SketchyBar (44px top bar)
yabai -m config external_bar all:44:0

# Multi-monitor stability signals
yabai -m signal --add event=display_added action="yabai -m space --balance"
yabai -m signal --add event=display_removed action="yabai -m space --balance"
yabai -m signal --add event=display_changed action="yabai -m space --balance"
yabai -m signal --add event=system_woke action="yabai -m space --balance"

# Fix windows after Mission Control operations (workaround without SA)
yabai -m signal --add event=space_changed action="yabai -m space --balance"
